#!/usr/bin/env python3
"""Initialize and remember a GDP runtime environment."""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
from typing import Dict, List


CONFIG_NAME = ".gdp-config.json"
RUNDIR_SUBDIRS = [
    "data-product",
    "data-product/gains",
    "data-product/gains/npz",
    "data-product/gains/csv",
    "data-product/stats",
    "data-product/stats/npz",
    "data-product/stats/csv",
    "data-product/ks",
    "data-product/ks/npz",
    "data-product/ks/csv",
    "data-product/self-corr",
    "data-product/self-corr/npz",
    "data-product/cross-corr",
    "data-product/cross-corr/npz",
    "data-product/cross-corr/csv",
    "data-product/flag",
    "data-product/flag/npz",
    "data-product/flag/csv",
    "logs",
    "plots",
    "plots/png",
    "plots/eps",
    "plots/pdf",
]


def project_root() -> Path:
    return Path(__file__).resolve().parents[1]


def default_config_path() -> Path:
    return project_root() / CONFIG_NAME


def load_config(path: Path) -> Dict[str, object]:
    if not path.exists():
        return {}
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


def write_config(path: Path, data: Dict[str, object]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    with tmp.open("w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, sort_keys=True)
        f.write("\n")
    tmp.replace(path)


def build_paths(rundir: Path) -> Dict[str, str]:
    return {
        "rundir": str(rundir),
        "data_product_dir": str(rundir / "data-product"),
        "gains_npz_dir": str(rundir / "data-product" / "gains" / "npz"),
        "gains_csv_dir": str(rundir / "data-product" / "gains" / "csv"),
        "stats_npz_dir": str(rundir / "data-product" / "stats" / "npz"),
        "stats_csv_dir": str(rundir / "data-product" / "stats" / "csv"),
        "ks_npz_dir": str(rundir / "data-product" / "ks" / "npz"),
        "ks_csv_dir": str(rundir / "data-product" / "ks" / "csv"),
        "self_corr_npz_dir": str(rundir / "data-product" / "self-corr" / "npz"),
        "cross_corr_npz_dir": str(rundir / "data-product" / "cross-corr" / "npz"),
        "cross_corr_csv_dir": str(rundir / "data-product" / "cross-corr" / "csv"),
        "flag_npz_dir": str(rundir / "data-product" / "flag" / "npz"),
        "flag_csv_dir": str(rundir / "data-product" / "flag" / "csv"),
        "logs_dir": str(rundir / "logs"),
        "plots_dir": str(rundir / "plots"),
        "plots_png_dir": str(rundir / "plots" / "png"),
        "plots_eps_dir": str(rundir / "plots" / "eps"),
        "plots_pdf_dir": str(rundir / "plots" / "pdf"),
    }


def ensure_rundir(rundir: Path, dry_run: bool = False) -> List[str]:
    created: List[str] = []
    for rel in [""] + RUNDIR_SUBDIRS:
        path = rundir / rel if rel else rundir
        if not path.exists():
            created.append(str(path))
            if not dry_run:
                path.mkdir(parents=True, exist_ok=True)
        elif not path.is_dir():
            raise NotADirectoryError(f"Path exists but is not a directory: {path}")
    return created


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description=(
            "Set up the GDP runtime directory and remember source-data/default "
            "product paths for other GDP commands."
        )
    )
    p.add_argument(
        "--rundir",
        default=None,
        help="Runtime directory to create/use. Default: existing config value, else <GDP>/rundir.",
    )
    p.add_argument(
        "--source-data",
        default=None,
        help="Source data directory to remember for later GDP commands.",
    )
    p.add_argument(
        "--gain-dir",
        default=None,
        help="Gain/bandpass table or directory to remember for later GDP commands. Alias for --source-data when --source-data is omitted.",
    )
    p.add_argument(
        "--config",
        default=None,
        help="Configuration JSON path. Default: <GDP>/.gdp-config.json.",
    )
    p.add_argument(
        "--show",
        action="store_true",
        help="Show the current saved configuration and exit.",
    )
    p.add_argument(
        "--dry-run",
        action="store_true",
        help="Print what would be created/written without changing files.",
    )
    p.add_argument(
        "--allow-missing-source",
        action="store_true",
        help="Allow --source-data to point to a directory that does not yet exist.",
    )
    return p.parse_args()


def main() -> None:
    args = parse_args()
    cfg_path = Path(args.config).expanduser().resolve() if args.config else default_config_path()
    old = load_config(cfg_path)

    if args.show:
        print(json.dumps(old, indent=2, sort_keys=True))
        return

    rundir = Path(
        args.rundir
        or old.get("rundir")
        or (project_root() / "rundir")
    ).expanduser().resolve()

    source_value = args.source_data or args.gain_dir or old.get("gain_dir") or old.get("source_data")
    if not source_value:
        raise SystemExit(
            "Source data directory is required for first setup. "
            "Pass --source-data /path/to/data."
        )
    source_data = Path(str(source_value)).expanduser().resolve()
    if not source_data.exists() and not args.allow_missing_source:
        raise FileNotFoundError(
            f"Source data directory does not exist: {source_data}\n"
            "Use --allow-missing-source if this path will be created later."
        )
    if source_data.exists() and not source_data.is_dir():
        raise NotADirectoryError(f"Source data path is not a directory: {source_data}")

    created = ensure_rundir(rundir, dry_run=args.dry_run)
    paths = build_paths(rundir)
    config: Dict[str, object] = {
        "project_root": str(project_root()),
        "source_data": str(source_data),
        "gain_dir": str(source_data),
        "config_file": str(cfg_path),
        "paths": paths,
        **paths,
    }

    if args.dry_run:
        print("Would create directories:")
        for item in created:
            print(f"  {item}")
        print("\nWould write configuration:")
        print(json.dumps(config, indent=2, sort_keys=True))
        return

    write_config(cfg_path, config)
    print(f"GDP configuration written: {cfg_path}")
    print(f"Runtime directory: {rundir}")
    print(f"Source data:       {source_data}")
    if created:
        print("Created directories:")
        for item in created:
            print(f"  {item}")
    else:
        print("Runtime directory structure already existed.")


if __name__ == "__main__":
    main()
